# Copy this file to .env and fill in your values before running docker compose.

# ── Application ────────────────────────────────────────────────────────────
EGG_NAMESPACE=__EGG_NAMESPACE__
EGG_APP_NAME=__EGG_APP_NAME__
EGG_VERSION=0.0.1
EGG_LICENSE=__EGG_LICENSE__
EGG_AUTHOR=__EGG_AUTHOR__
EGG_YEAR=2025
EGG_PORT=__EGG_PORT__

# ── Auth0 ───────────────────────────────────────────────────────────────────
EGG_AUTH0_DOMAIN=__EGG_AUTH0_DOMAIN__
EGG_AUTH0_AUDIENCE=__EGG_AUTH0_AUDIENCE__
EGG_AUTH0_CLIENT_ID=__EGG_AUTH0_CLIENT_ID__
EGG_AUTH0_CLIENT_SECRET=__EGG_AUTH0_CLIENT_SECRET__

# ── Database (SQLC / Goose config) ─────────────────────────────────────────
EGG_MIGRATION_PROTO=postgres
EGG_MIGRATION_DEST=db/migrations
EGG_SQLC_REPO=db/repository
EGG_SQLC_SCHEMA=db/migrations
EGG_SQLC_TYPE=go
EGG_DB_QUERIES=db/queries

# Used locally (outside Docker). In Docker, EGG_DB_URL is overridden by compose.
EGG_DB_URL=postgres://postgres:changeme@localhost:5432/appdb

# ── Frontend ────────────────────────────────────────────────────────────────
EGG_FRONTEND_DIR=web/dist
EGG_FRONTEND_API=web/src/api

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=appdb
POSTGRES_HOST_PORT=5432

# ── Dragonfly / Redis ───────────────────────────────────────────────────────
REDIS_HOST_PORT=6379

# Used locally (outside Docker). In Docker, EGG_CACHE_URL is overridden by compose.
EGG_CACHE_URL=redis://localhost:6379

# ── MinIO (S3) ──────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# Used locally (outside Docker). In Docker, EGG_S3_* are overridden by compose.
EGG_S3_URL=http://localhost:9000
EGG_S3_ACCESS=minioadmin
EGG_S3_SECRET=minioadmin123
EGG_S3_SECURE=false

# ── Host port for the app container ────────────────────────────────────────
APP_HOST_PORT=__EGG_PORT__
